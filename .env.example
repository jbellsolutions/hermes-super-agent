# ============================================================
# agent-os — environment variables
# Copy to .env and fill in. Never commit .env.
# ============================================================

# --- Super Agent identity & mode ---
HERMES_PROFILE=supersan
# Power level: saiyan (lite) | super-saiyan (full).
# Server deploys (Railway/Docker/VPS) default to super-saiyan when unset.
INSTALL_MODE=super-saiyan

# --- Models / providers ---
# Locked-in Super Agent stack: Kimi K2.6 for planning, served by Together AI
# (an OpenAI-compatible endpoint). Hermes reads HERMES_MODEL /
# HERMES_INFERENCE_PROVIDER / HERMES_BASE_URL — scripts/start.sh writes these
# into the profile config.yaml on every boot.
HERMES_MODEL=moonshotai/Kimi-K2.6
HERMES_INFERENCE_PROVIDER=custom
HERMES_BASE_URL=https://api.together.xyz/v1
# Together AI key — the one secret you must fill in (https://api.together.xyz).
# OPENAI_API_KEY mirrors it: the "custom" provider reads the OpenAI-wire key.
TOGETHER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.together.xyz/v1
# Worker pool — DeepSeek V4 Pro primary, plus GLM 5.1 + Mixtral + Kimi (all Together AI).
HERMES_WORKER_MODEL=deepseek-ai/DeepSeek-V4-Pro
HERMES_WORKER_MODELS=deepseek-ai/DeepSeek-V4-Pro,zai-org/GLM-5.1,mistralai/Mixtral-8x22B-Instruct-v0.1,moonshotai/Kimi-K2.6
# Architecture/security reviews — Claude Haiku direct (optional).
ANTHROPIC_API_KEY=
HERMES_ARCHITECTURE_MODELS=claude-haiku-4-5-20251001
# Other providers (optional).
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NOUS_PORTAL_API_KEY=

# --- Commercial/onboarding profile ---
BUSINESS_NAME=
BUSINESS_TYPE=
FIRST_WORKFLOWS=
HUMAN_APPROVAL_REQUIRED=production deploys, payments, destructive infra changes, outbound sending

# --- Channels ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# --- Voice ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Voice realtime model: openai | gemini
VOICE_REALTIME_PROVIDER=openai

# --- Vault / persistence / shared brain ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
VAULT_ROOT=./vault
OBSIDIAN_VAULT_PATH=
NOTION_API_KEY=
NOTION_CONVERSATIONS_DB=
NOTION_ACTIONS_DB=
NOTION_DECISIONS_DB=
NOTION_AGENTS_DB=
NOTION_COMPANIES_DB=
NOTION_DEPLOYMENTS_DB=
NOTION_APPROVALS_DB=
NOTION_COSTS_DB=
SHARED_BRAIN_SYNC_MODE=bidirectional

# --- Specialist runtime keys ---
EXA_API_KEY=
E2B_API_KEY=
CURSOR_API_KEY=
APOLLO_API_KEY=
SMARTLEAD_API_KEY=

# --- Fabric: NATS + Temporal + Coordinator (see SETUP.md steps 1-3) ---
NATS_URL=
TEMPORAL_HOST=
COORDINATOR_URL=
COORDINATOR_DEFAULT_MODEL=claude-sonnet-4-5

# --- Fabric: COO Specialist channels (Step 4) ---
RETELL_API_KEY=
RETELL_AGENT_ID=
INSTANTLY_API_KEY=

# --- Fabric: Tier 1 spawning via Archon (Step 5) ---
ARCHON_A2A_URL=
RAILWAY_API_KEY=

# --- Fabric: Tier 2 spawning via DO/Hetzner (Step 6) ---
DO_API_TOKEN=
DO_SSH_KEY_FINGERPRINT=
HETZNER_API_TOKEN=
HETZNER_SSH_KEY_ID=
SSH_PRIVATE_KEY_PATH=
VPS_SSH_USER=root

# --- Fabric: Admiral A2A server ---
HERMES_BASE_URL=
HERMES_A2A_PORT=8080

# --- Fabric: Observability via AgentOps (Step 8) ---
AGENTOPS_API_KEY=

# --- Optional: Agent Zero browser stack ---
AGENT_ZERO_URL=http://127.0.0.1:5080

# --- Deployment providers (optional; never commit real values) ---
RAILWAY_TOKEN=
DIGITALOCEAN_ACCESS_TOKEN=

# --- Optional managed cloud computer (Enterprise only) ---
ORGO_API_KEY=
ORGO_ENABLED=false

# --- Composio (built-in tool access for Hermes) ---
# One key gives Hermes 250+ SaaS connectors. Connections (Slack, Linear, Gmail,
# etc.) are created on demand via composio.connect(app) and persisted to
# vault/composio/connections.yaml.
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=https://backend.composio.dev
COMPOSIO_TIMEOUT=60

# --- Observability ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ENABLE_NEMO_AGENT_TOOLKIT=false

# --- Upgrader ---
UPGRADER_CRON=0 2 * * *
UPGRADER_ENABLE_NEMOCLAW=false   # flip to true when NVIDIA marks it GA

# --- Soft cost caps (Slack-alert at 80%) ---
DAILY_TOKEN_BUDGET_USD=50
VOICE_MINUTE_BUDGET_USD=20

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3001
