# ============================================================
# agent-os — environment variables
# Copy to .env and fill in. Never commit .env.
# ============================================================

# --- Models / providers ---
HERMES_PROVIDER=openrouter
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NOUS_PORTAL_API_KEY=

# Default model for Hermes. For commercial Super Agent installs, prefer a router/profile
# that can use both GPT-5.5 and Claude Opus 4.6/4.7 for architecture/debug/security/auth/tests.
HERMES_DEFAULT_MODEL=claude-opus-4-7
HERMES_ARCHITECTURE_MODELS=gpt-5.5,claude-opus-4-7
HERMES_WORKER_MODEL=deepseek

# --- Commercial/onboarding profile ---
# Tier: operator | pro-operator | enterprise
SUPER_AGENT_TIER=operator
BUSINESS_NAME=
BUSINESS_TYPE=
FIRST_WORKFLOWS=
HUMAN_APPROVAL_REQUIRED=production deploys, payments, destructive infra changes, outbound sending

# --- Channels ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# --- Voice ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Voice realtime model: openai | gemini
VOICE_REALTIME_PROVIDER=openai

# --- Vault / persistence / shared brain ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
VAULT_ROOT=./vault
OBSIDIAN_VAULT_PATH=
NOTION_API_KEY=
NOTION_CONVERSATIONS_DB=
NOTION_ACTIONS_DB=
NOTION_DECISIONS_DB=
NOTION_AGENTS_DB=
NOTION_COMPANIES_DB=
NOTION_DEPLOYMENTS_DB=
NOTION_APPROVALS_DB=
NOTION_COSTS_DB=
SHARED_BRAIN_SYNC_MODE=bidirectional

# --- Specialist runtime keys ---
EXA_API_KEY=
E2B_API_KEY=
CURSOR_API_KEY=
APOLLO_API_KEY=
SMARTLEAD_API_KEY=

# --- Deployment providers (optional; never commit real values) ---
RAILWAY_TOKEN=
DIGITALOCEAN_ACCESS_TOKEN=

# --- Optional managed cloud computer (Enterprise only) ---
ORGO_API_KEY=
ORGO_ENABLED=false

# --- Composio (built-in tool access for Hermes) ---
# One key gives Hermes 250+ SaaS connectors. Connections (Slack, Linear, Gmail,
# etc.) are created on demand via composio.connect(app) and persisted to
# vault/composio/connections.yaml.
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=https://backend.composio.dev
COMPOSIO_TIMEOUT=60

# --- Observability ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ENABLE_NEMO_AGENT_TOOLKIT=false

# --- Upgrader ---
UPGRADER_CRON=0 2 * * *
UPGRADER_ENABLE_NEMOCLAW=false   # flip to true when NVIDIA marks it GA

# --- Soft cost caps (Slack-alert at 80%) ---
DAILY_TOKEN_BUDGET_USD=50
VOICE_MINUTE_BUDGET_USD=20

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3001
